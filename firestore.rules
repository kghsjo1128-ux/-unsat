rules_version = '2';
// 배포: firebase deploy --only firestore:rules
//
// ★ 관리자 이메일은 public/admin.html 의 ADMIN_EMAILS 와 반드시 동일하게 유지하세요.
//    (규칙에서 request.auth.token.email 과 비교합니다.)
//
// ★ sharedData 는 여전히 "로그인 사용자 누구나" 덮어쓰기 가능합니다.
//    악용·오류 방지는 Cloud Functions 등 서버 쓰기로 이전하는 것이 이상적입니다.
//
service cloud.firestore {
  match /databases/{database}/documents {

    function adminEmails() {
      return [
        'hohohorhrh@naver.com',
      ];
    }

    function isAdminEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email in adminEmails();
    }

    // 앱 공용 JSON blob — 읽기 공개, 쓰기는 로그인 + 필드 형식·크기 제한
    match /sharedData/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasAll(['data', 'updatedAt'])
        && request.resource.data.data is string
        && request.resource.data.data.size() < 900000;
    }

    // 회원 프로필 — 본인 또는 관리자(이메일 화이트리스트)만
    match /users/{userId} {
      allow get: if (request.auth != null && request.auth.uid == userId)
        || isAdminEmail();
      allow list: if isAdminEmail();

      // 가입 시: 본인 문서만, isAdmin 필드 없이 생성
      allow create: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['isAdmin']);

      // 본인: 이름만 변경 가능, isAdmin 불변
      // 관리자: 전체 수정(정지·isAdmin 등)
      allow update: if isAdminEmail()
        || (request.auth != null
            && request.auth.uid == userId
            && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name'])
           );

      allow delete: if (request.auth != null && request.auth.uid == userId)
        || isAdminEmail();
    }

    match /users/{userId}/private/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 동의 로그: 본인 생성만, 열람은 관리자만 (일반 유저 간 개인정보 노출 방지)
    match /consentLog/{id} {
      allow create: if request.auth != null;
      allow read: if isAdminEmail();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
